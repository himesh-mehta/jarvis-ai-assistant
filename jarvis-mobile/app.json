{
  "expo": {
    "name": "Jarvis",
    "slug": "jarvis-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "jarvis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {

      "supportsTablet": true,
      "bundleIdentifier": "com.jarvis.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.jarvis.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}